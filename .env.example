# ============================================
# AI Debate Arena Revival - Environment Configuration
# ============================================
# Copy this file to .env and fill in your actual values

# ----------------
# Database
# ----------------
# Neon PostgreSQL connection string
# For Render deployment, add ?pgbouncer=true for connection pooling
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# ----------------
# Cache
# ----------------
# Upstash Redis for caching and real-time updates
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_redis_token

# ----------------
# LLM Providers
# ----------------
# Azure OpenAI for infrastructure roles such as fact-checking or tie-breaking.
# The deployment name is the Azure deployment, not necessarily the base model name.
# NOTE: AZURE_OPENAI_ENDPOINT must be the bare resource origin
#   (https://<resource>.openai.azure.com) WITHOUT a /openai/v1 path suffix.
# GPT-5-series deployments (e.g. gpt-5.5) are auto-detected and sent
# max_completion_tokens (max_tokens is rejected by those models).
AZURE_OPENAI_API_KEY=your_azure_openai_key
AZURE_OPENAI_API_INSTANCE_NAME=your_resource_name
# Either AZURE_OPENAI_API_DEPLOYMENT_NAME or AZURE_OPENAI_DEPLOYMENT_NAME is accepted.
AZURE_OPENAI_API_DEPLOYMENT_NAME=your_chat_deployment_name
AZURE_OPENAI_API_VERSION=2024-12-01-preview
# Optional alternative to AZURE_OPENAI_API_INSTANCE_NAME when using a custom endpoint.
AZURE_OPENAI_ENDPOINT=

# Anthropic (Claude 4.5)
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key

# Google Gemini (AI Studio / Generative Language API).
# GOOGLE_API_KEY is the legacy name; GEMINI_API_KEY (+ optional backup) is preferred.
GOOGLE_API_KEY=your_google_api_key
GEMINI_API_KEY=your_gemini_api_key
GEMINI_API_KEY_BACKUP=your_backup_gemini_api_key
# Gemini model ids used for judge/infra Gemini calls (primary + fallback).
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_MODEL_BACKUP=gemini-3-flash-preview

# xAI (Grok 4.1)
XAI_API_KEY=xai-your_xai_key

# OpenRouter (debater model variety and fallback)
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_key

# ----------------
# Search / Fact-check evidence
# ----------------
# Tavily Search (primary web-evidence source for fact-checking)
TAVILY_API_KEY=tvly-your_tavily_key
# Firecrawl (fallback web search when Tavily returns nothing / is down)
FIRECRAWL_API_KEY=fc-your_firecrawl_key
# Google Fact Check Tools API (authoritative publisher fact-check ratings layer)
GOOGLE_FACTCHECK_API_KEY=your_google_factcheck_api_key

# ----------------
# Authentication (deferred for revival MVP)
# ----------------
# Stack Auth configuration for Next.js (currently not part of revival MVP)
# Note: NEXT_PUBLIC_ prefix exposes these to the browser (client-side)
NEXT_PUBLIC_STACK_PROJECT_ID=your_stack_project_id
NEXT_PUBLIC_STACK_PUBLISHABLE_CLIENT_KEY=pck_your_publishable_key
# Server-only secret (no NEXT_PUBLIC_ prefix)
STACK_SECRET_SERVER_KEY=ssk_your_secret_key

# NextAuth (Backup/Alternative - currently using Neon Auth)
NEXTAUTH_SECRET=your_nextauth_secret_min_32_chars
NEXTAUTH_URL=http://localhost:3000

# ----------------
# Monitoring (Optional)
# ----------------
# Sentry for error tracking
SENTRY_DSN=

# ----------------
# Application Settings
# ----------------
# Node environment
NODE_ENV=development

# API rate limiting
RATE_LIMIT_ANONYMOUS=100
RATE_LIMIT_AUTHENTICATED=500

# Daily spending caps (in USD)
DAILY_SPENDING_CAP_DEV=10
DAILY_SPENDING_CAP_STAGING=50
DAILY_SPENDING_CAP_PROD=500
