# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
desktop.ini
llm-council-master/
Binder101.pdf
debateround1.txt

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# env files (never commit real secrets)
.env
.env*.local
.env.production

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# archive (old prototype)
/archive/*
!/archive/README.md
!/archive/product-era/
!/archive/product-era/**
/docs/archive/
/scripts/archive/
